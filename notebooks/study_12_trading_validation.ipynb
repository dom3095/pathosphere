   "source": [
    "# Study 12 — Trading Validation (Data Inventory)\n",
    "\n",
    "Check paper trading state: trades, portfolios, equity curves."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sqlite3\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "\n",
    "DB = Path('data/db/pathosphere.db')\n",
    "CONN = sqlite3.connect(str(DB))\n",
    "CONN.row_factory = sqlite3.Row\n",
    "print(f\"DB: {DB}\")"
   ]
  },
  {
   "cell_type": {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": "# Trading inventory\ntrades_total = CONN.execute(\"SELECT COUNT(*) as c FROM trades\").fetchone()['c']\nports_total = CONN.execute(\"SELECT COUNT(*) as c FROM portfolios\").fetchone()['c']\n\nprint(f\"Trades: {trades_total}\")\nprint(f\"Portfolios: {ports_total}\")\n\nif trades_total == 0:\n    print(\"\\n✓ Phase 3 (trading) not yet populated. Run: uv run pathos cycle\")\nelse:\n    print(\"\\n✓ Paper trading data present\")\n    \n    # Show portfolio summary\n    ports = CONN.execute(\"\"\"\n        SELECT name, initial_capital, current_balance FROM portfolios\n    \"\"\").fetchall()\n    \n    if ports:\n        print(\"\\nPortfolios:\")\n        for p in ports:\n            pnl = p['current_balance'] - p['initial_capital']\n            ret = 100 * pnl / p['initial_capital']\n            print(f\"  {p['name']:20} init={p['initial_capital']:10.0f} curr={p['current_balance']:10.0f} ({ret:+6.1f}%)\")\n    \n    # Check if equity curves can be computed\n    closed = CONN.execute(\"SELECT COUNT(*) as c FROM trades WHERE status = 'closed'\").fetchone()['c']\n    print(f\"\\nClosed trades: {closed} (need ≥10 for meaningful curves)\")"
   ]
  },
  {
   "cell_type": {"cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": "# Summary\nphase3_ready = trades_total > 10 and ports_total >= 3\nprint(f\"\"\"\n{'='*60}\nSTATUS\n{'='*60}\nTrades populated: {bool(trades_total)} \nPortfolios ready: {ports_total}/3\nPhase 3 ready for validation: {phase3_ready}\n\nNext step: {'Run Study 12 properly with equity curves' if phase3_ready else 'Run: uv run pathos cycle'}\n\"\"\")"
   ]
  }
