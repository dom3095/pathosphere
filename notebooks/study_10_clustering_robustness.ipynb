{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Study 10 — Clustering Robustness (Data-Driven Analysis)\n",
    "\n",
    "Analizza il clustering attuale nel DB. Verifica coerenza cluster e qualità titoli."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sqlite3\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "\n",
    "DB = Path('data/db/pathosphere.db')\n",
    "CONN = sqlite3.connect(str(DB))\n",
    "CONN.row_factory = sqlite3.Row\n",
    "print(f\"DB: {DB}, {DB.stat().st_size / 1e6:.0f}MB\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. DB State Overview"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "total_events = CONN.execute(\"SELECT COUNT(*) as c FROM events\").fetchone()['c']\n",
    "total_docs = CONN.execute(\"SELECT COUNT(*) as c FROM event_documents\").fetchone()['c']\n",
    "\n",
    "origins = CONN.execute(\"\"\"\n",
    "    SELECT origin, COUNT(DISTINCT e.id) as events, COUNT(ed.document_id) as docs\n",
    "    FROM events e\n",
    "    LEFT JOIN event_documents ed ON e.id = ed.event_id\n",
    "    GROUP BY origin ORDER BY events DESC\n",
    "\"\"\").fetchall()\n",
    "\n",
    "print(f\"Total events: {total_events:,} | Total docs in events: {total_docs:,}\")\n",
    "print(\"\\nBy origin:\")\n",
    "for r in origins:\n",
    "    print(f\"  {str(r['origin'] or 'NULL'):12} {r['events']:7,} events {r['docs'] or 0:7,} docs\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. RSS/Comtrade Cluster Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "rss = CONN.execute(\"\"\"\n",
    "    SELECT e.id, e.title, COUNT(ed.document_id) as size FROM events e\n",
    "    LEFT JOIN event_documents ed ON e.id = ed.event_id\n",
    "    WHERE e.origin IN ('rss','comtrade') GROUP BY e.id ORDER BY size DESC\n",
    "\"\"\").fetchall()\n",
    "\n",
    "sizes = [r['size'] for r in rss]\n",
    "print(f\"RSS/Comtrade: {len(rss)} events, {sum(sizes)} docs\")\n",
    "print(f\"  Singleton: {sum(1 for s in sizes if s == 1)} ({100*sum(1 for s in sizes if s == 1)/len(rss):.1f}%)\")\n",
    "print(f\"  Mean size: {np.mean(sizes):.2f}\")\n",
    "print(f\"  Max size: {max(sizes)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Top 10 Cluster Titles"
   ]
  },
  {
   "cell_type": {"text": "\n"}, "metadata": {},
   "source": [
    "Inspect largest clusters for readable titles"
   ]
  },
  {
   "cell_type": {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": "print(\"Top 10 Largest Clusters:\")\nprint(\"=\"*100)\nfor i, r in enumerate(rss[:10], 1):\n    is_garbage = r['title'].startswith('||') if r['title'] else False\n    mark = \" ❌ GARBAGE\" if is_garbage else \" ✓\"\n    print(f\"{i:2}. [{r['size']:2} docs]{mark}  {r['title'][:90]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Cluster Size Distribution"
   ]
  },
  {
   "cell_type": {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 4))\n\nax1.hist(sizes, bins=30, edgecolor='black', alpha=0.7)\nax1.set_xlabel('Docs per Cluster')\nax1.set_ylabel('Frequency')\nax1.set_title('Cluster Size (Linear)')\nax1.grid(alpha=0.3)\n\nax2.hist(sizes, bins=30, edgecolor='black', alpha=0.7)\nax2.set_xlabel('Docs per Cluster')\nax2.set_ylabel('Frequency (log)')\nax2.set_yscale('log')\nax2.set_title('Cluster Size (Log) — check for bimodal')\nax2.grid(alpha=0.3)\n\nplt.tight_layout()\nplt.savefig('study_10_sizes.png', dpi=100, bbox_inches='tight')\nplt.show()\nprint(\"✓ study_10_sizes.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Sample Titles from Top 3 Clusters"
   ]
  },
  {
   "cell_type": {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": "for i, cluster in enumerate(rss[:3]):\n    docs = CONN.execute(\"\"\"\n        SELECT r.title FROM event_documents ed\n        JOIN raw_documents r ON ed.document_id = r.id\n        WHERE ed.event_id = ? ORDER BY r.published_at DESC LIMIT 3\n    \"\"\", (cluster['id'],)).fetchall()\n    \n    print(f\"\\n[{i+1}] Event {cluster['id']} — {cluster['size']} docs\")\n    print(f\"    Cluster title: {cluster['title'][:80]}\")\n    print(\"    Sample doc titles:\")\n    for d in docs:\n        print(f\"      • {d['title'][:75]}\")"
   ]
  },
  {
   "cell_type": {"text": "\n"}, "metadata": {},
   "source": [
    "## 6. Coherence Check"
   ]
  },
  {
   "cell_type": {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": "# Check embeddings for large clusters\nlarge = CONN.execute(\"\"\"\n    SELECT e.id FROM events e JOIN event_documents ed ON e.id = ed.event_id\n    WHERE e.origin IN ('rss','comtrade')\n    GROUP BY e.id HAVING COUNT(*) >= 5 ORDER BY COUNT(*) DESC LIMIT 50\n\"\"\").fetchall()\n\ncoh_scores = []\nfor event in large:\n    rows = CONN.execute(\"\"\"\n        SELECT vd.embedding FROM event_documents ed\n        JOIN vec_documents vd ON ed.document_id = vd.document_id\n        WHERE ed.event_id = ?\n    \"\"\", (event['id'],)).fetchall()\n    \n    if len(rows) >= 2:\n        embs = [np.frombuffer(r['embedding'], dtype=np.float32) for r in rows if r['embedding']]\n        if embs:\n            embs = np.array(embs)\n            centroid = embs.mean(axis=0)\n            avg_dist = np.mean([np.linalg.norm(e - centroid) for e in embs])\n            avg_sim = 1 - avg_dist**2 / 2\n            coh_scores.append(avg_sim)\n\nif coh_scores:\n    print(f\"Coherence (avg similarity to centroid) for {len(coh_scores)} clusters ≥5 docs:\")\n    print(f\"  Mean: {np.mean(coh_scores):.3f}\")\n    print(f\"  Min:  {np.min(coh_scores):.3f}\")\n    print(f\"  Threshold 0.88: {sum(1 for c in coh_scores if c >= 0.88)}/{len(coh_scores)} pass\")\nelse:\n    print(\"No embeddings found\")"
   ]
  },
  {
   "cell_type": {"text": "\n"}, "metadata": {},
   "source": [
    "## 7. Verdict"
   ]
  },
  {
   "cell_type": {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": "garbage_count = CONN.execute(\"SELECT COUNT(*) FROM events WHERE title LIKE '||%'\").fetchone()[0]\n\nprint(f\"\"\"\nVERDICT\n=======\n✓ RSS events: {len(rss)}\n✓ Singleton rate: {100*sum(1 for s in sizes if s == 1)/len(rss):.1f}%\n✓ Top titles readable: {all(not r['title'].startswith('||') for r in rss[:10] if r['title'])}\n✓ GDELT garbage titles: {garbage_count} (should be 0)\n✓ Coherence: {f'{np.mean(coh_scores):.3f}' if coh_scores else 'N/A'}\n\nClustering: {'SOLID ✓' if garbage_count == 0 else 'NEEDS FIX ❌'}\n\"\"\")"
   ]
  }
 ],
