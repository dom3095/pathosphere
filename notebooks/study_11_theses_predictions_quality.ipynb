   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Study 11 — Theses & Predictions (What's Actually There)\n",
    "\n",
    "Analizza tesi e predizioni presenti nel DB. No assunzioni."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sqlite3\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "\n",
    "DB = Path('data/db/pathosphere.db')\n",
    "CONN = sqlite3.connect(str(DB))\n",
    "CONN.row_factory = sqlite3.Row\n",
    "print(f\"DB: {DB}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Theses Inventory"
   ]
  },
  {
   "cell_type": {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": "# Count theses\ntotal = CONN.execute(\"SELECT COUNT(*) as c FROM theses\").fetchone()['c']\nby_status = CONN.execute(\"\"\"\n    SELECT status, COUNT(*) as c FROM theses GROUP BY status\n\"\"\").fetchall()\n\nprint(f\"Total theses: {total}\")\nif total > 0:\n    for r in by_status:\n        print(f\"  {r['status']:12} {r['c']}\")\nelse:\n    print(\"  (empty)\")"
   ]
  },
  {
   "cell_type": {"text": "\n"}, "metadata": {},
   "source": [
    "## 2. Predictions Inventory"
   ]
  },
  {
   "cell_type": {"cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": "# Count predictions\npred_total = CONN.execute(\"SELECT COUNT(*) as c FROM predictions\").fetchone()['c']\nprint(f\"Total predictions: {pred_total}\")\n\nif pred_total > 0:\n    # Sample\n    preds = CONN.execute(\"\"\"\n        SELECT id, probability, macro_area, time_horizon_class, \n               outcome_eventual, outcome_on_time\n        FROM predictions LIMIT 5\n    \"\"\").fetchall()\n    \n    print(\"\\nSample predictions:\")\n    for p in preds:\n        print(f\"  P{p['id']:5} | prob={p['probability']:.2f} | {p['macro_area']:12} | {p['time_horizon_class']:8} | out={p['outcome_eventual']}\")\nelse:\n    print(\"  (empty)\")"
   ]
  },
  {
   "cell_type": {"text": "\n"}, "metadata": {},
   "source": [
    "## 3. If Predictions Exist: Calibration"
   ]
  },
  {
   "cell_type": {"cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": "# If predictions exist, check calibration\nif pred_total > 0:\n    resolved = CONN.execute(\"\"\"\n        SELECT COUNT(*) as c FROM predictions WHERE outcome_eventual IS NOT NULL\n    \"\"\").fetchone()['c']\n    \n    print(f\"Resolved predictions (outcome_eventual not null): {resolved} / {pred_total}\")\n    \n    if resolved > 0:\n        # Brier score\n        brier = CONN.execute(\"\"\"\n            SELECT AVG((probability - CAST(outcome_eventual AS FLOAT))*(probability - CAST(outcome_eventual AS FLOAT))) as brier\n            FROM predictions WHERE outcome_eventual IS NOT NULL\n        \"\"\").fetchone()['brier']\n        \n        print(f\"  Mean Brier: {brier:.4f}\")\n        \n        # Bucket calibration\n        buckets = CONN.execute(\"\"\"\n            SELECT \n                CASE WHEN probability < 0.2 THEN '0-20%'\n                     WHEN probability < 0.4 THEN '20-40%'\n                     WHEN probability < 0.6 THEN '40-60%'\n                     WHEN probability < 0.8 THEN '60-80%'\n                     ELSE '80-100%' END as bucket,\n                COUNT(*) as n,\n                SUM(CAST(outcome_eventual AS INTEGER)) as successes\n            FROM predictions WHERE outcome_eventual IS NOT NULL\n            GROUP BY bucket\n        \"\"\").fetchall()\n        \n        print(\"\\n  Calibration by bucket:\")\n        for b in buckets:\n            acc = b['successes'] / b['n'] if b['n'] > 0 else 0\n            print(f\"    {b['bucket']:8} | n={b['n']:3} | accuracy={acc:.2f}\")\n    else:\n        print(\"  No resolved predictions yet\")\nelse:\n    print(\"No predictions data\")"
   ]
  },
  {
   "cell_type": {"text": "\n"}, "metadata": {},
   "source": [
    "## 4. Trades Inventory"
   ]
  },
  {
   "cell_type": {"cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": "# Count trades\ntrade_total = CONN.execute(\"SELECT COUNT(*) as c FROM trades\").fetchone()['c']\nprint(f\"Total trades: {trade_total}\")\n\nif trade_total > 0:\n    by_status = CONN.execute(\"\"\"\n        SELECT status, COUNT(*) as c FROM trades GROUP BY status\n    \"\"\").fetchall()\n    for r in by_status:\n        print(f\"  {r['status']:10} {r['c']}\")\n\n# Portfolios\nport_total = CONN.execute(\"SELECT COUNT(*) as c FROM portfolios\").fetchone()['c']\nprint(f\"\\nTotal portfolios: {port_total}\")\n\nif port_total > 0:\n    ports = CONN.execute(\"\"\"\n        SELECT name, initial_capital, current_balance FROM portfolios\n    \"\"\").fetchall()\n    for p in ports:\n        pnl = p['current_balance'] - p['initial_capital']\n        ret = 100 * pnl / p['initial_capital']\n        print(f\"  {p['name']:15} initial={p['initial_capital']:.0f} current={p['current_balance']:.0f} ({ret:+.1f}%)\")"
   ]
  },
  {
   "cell_type": {"text": "\n"}, "metadata": {},
   "source": [
    "## 5. Status Summary"
   ]
  },
  {
   "cell_type": {"cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": "print(f\"\"\"\nSTATUS SUMMARY\n==============\nTheses: {total} (need ≥10 approved)\nPredictions: {pred_total} (need ≥20 for calibration)\nTrades: {trade_total} (need ≥10 for meaningful test)\nPortfolios: {port_total} (need 3: agent, random, buy&hold)\n\nNext: Run pathos cycle to populate Fase 3 data\n\"\"\")"
   ]
  }
 ],
