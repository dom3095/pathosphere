# Pathosphere — copia in .env e adatta

# Database
DB_PATH=data/db/pathosphere.db
PARQUET_DIR=data/parquet

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text  # usato solo per fallback; e5-small via sentence-transformers

# Embedding (sentence-transformers, locale)
EMBED_MODEL_NAME=intfloat/multilingual-e5-small

# Logging
LOG_LEVEL=INFO
LOG_DIR=data/logs

# Geocoding (Nominatim, locale via geopy — nessuna API key)
NOMINATIM_USER_AGENT=pathosphere/0.1

# Opzionali / futuri
# GDELT_LOOKBACK_DAYS=3
# COMTRADE_LOOKBACK_MONTHS=3
FIRMS_MAP_KEY=your_firms_map_key_here
